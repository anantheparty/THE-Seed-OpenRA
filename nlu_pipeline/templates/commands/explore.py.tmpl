try:
    _step_messages = []
    units = api.query_actor($units)
    if not units:
        raise RuntimeError("未找到可侦察单位")
    api.dispatch_explore(units)
    logger.info("已派出侦察单位")
    _step_messages.append("已派出侦察单位")
    __result__ = {
        "success": True,
        "message": _step_messages[-1],
        "observations": ""
    }
except Exception as e:
    __result__ = {
        "success": False,
        "message": f"执行失败: {e}",
        "observations": ""
    }
